/**
 * pages/recipe-detail/recipe-detail.wxss - 食谱详情页面样式
 */

.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 食谱详情 */
.recipe-detail {
  padding-bottom: 40rpx;
}

/* 头部 */
.recipe-header {
  position: relative;
  height: 400rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
}

.recipe-header__image {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recipe-header__placeholder {
  font-size: 120rpx;
}

.recipe-header__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

.recipe-header__category {
  display: inline-block;
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #4CAF50;
}

/* 基本信息 */
.recipe-info {
  background-color: #ffffff;
  padding: 24rpx;
  margin: -40rpx 24rpx 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.recipe-info__main {
  margin-bottom: 20rpx;
}

.recipe-info__title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.recipe-info__meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-item__icon {
  font-size: 24rpx;
}

.meta-item__text {
  font-size: 22rpx;
  color: #999999;
}

.recipe-info__actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}

.action-btn__icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.action-btn__text {
  font-size: 22rpx;
  color: #666666;
}

/* 简介 */
.recipe-description {
  background-color: #ffffff;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 12rpx;
}

.recipe-description__text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 营养信息 */
.nutrition-section {
  background-color: #ffffff;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 12rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-header__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.section-header__subtitle {
  font-size: 22rpx;
  color: #999999;
}

.section-header__step {
  font-size: 22rpx;
  color: #4CAF50;
}

.nutrition-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.nutrition-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background-color: #F9F9F9;
  border-radius: 8rpx;
}

.nutrition-card--primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8A80 100%);
}

.nutrition-card--primary .nutrition-card__label {
  color: rgba(255, 255, 255, 0.9);
}

.nutrition-card--primary .nutrition-card__value {
  color: #ffffff;
}

.nutrition-card__value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.nutrition-card__label {
  font-size: 20rpx;
  color: #999999;
}

/* 热量分布 */
.calorie-distribution {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.distribution-item {
  position: relative;
  height: 32rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  overflow: hidden;
}

.distribution-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  border-radius: 16rpx;
  transition: width 0.3s ease;
}

.distribution-label {
  position: absolute;
  left: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
  color: #333333;
}

/* 食材清单 */
.ingredients-section {
  background-color: #ffffff;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 12rpx;
}

.ingredients-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background-color: #F9F9F9;
  border-radius: 8rpx;
}

.ingredient-item__info {
  flex: 1;
}

.ingredient-item__name {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.ingredient-item__amount {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

.ingredient-item__check {
  font-size: 32rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
}

/* 份量控制 */
.servings-control {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.servings-control__label {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.servings-control__options {
  display: flex;
  gap: 12rpx;
}

.servings-option {
  flex: 1;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.servings-option--active {
  background-color: #4CAF50;
  color: #ffffff;
}

/* 制作步骤 */
.steps-section {
  background-color: #ffffff;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 12rpx;
}

.steps-nav {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 8rpx 0;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 50%;
  font-size: 22rpx;
  color: #999999;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.step-dot--active {
  background-color: #4CAF50;
  color: #ffffff;
  transform: scale(1.1);
}

.step-content {
  margin-bottom: 24rpx;
}

.step-number {
  font-size: 24rpx;
  font-weight: 600;
  color: #4CAF50;
  margin-bottom: 12rpx;
}

.step-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.step-controls {
  display: flex;
  gap: 16rpx;
}

.step-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.step-btn--prev {
  background-color: #F5F5F5;
  color: #666666;
}

.step-btn--next {
  background-color: #4CAF50;
  color: #ffffff;
}

.step-btn--disabled {
  opacity: 0.4;
}

/* 小贴士 */
.tips-section {
  background-color: #FFF8E1;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 12rpx;
}

.tips-content {
  display: flex;
  gap: 12rpx;
}

.tips-icon {
  font-size: 32rpx;
}

.tips-text {
  flex: 1;
  font-size: 24rpx;
  color: #F57C00;
  line-height: 1.6;
}

/* 标签 */
.tags-section {
  background-color: #ffffff;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 12rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 8rpx 20rpx;
  background-color: #F5F5F5;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666666;
}
