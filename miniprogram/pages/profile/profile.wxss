/**
 * pages/profile/profile.wxss - 个人资料页面样式
 */

.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 头部 */
.profile-header {
  position: relative;
  padding: 60rpx 24rpx 40rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #ffffff;
}

.profile-header__bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.1;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="20" cy="20" r="40" fill="white" opacity="0.1"/></svg>');
  background-size: 200rpx;
}

.profile-header__content {
  position: relative;
  display: flex;
  align-items: center;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  margin-right: 20rpx;
}

.profile-avatar__icon {
  font-size: 48rpx;
}

.profile-info {
  flex: 1;
}

.profile-info__name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.profile-info__goal {
  display: block;
  font-size: 22rpx;
  opacity: 0.9;
}

.profile-header__edit {
  padding: 12rpx;
}

.edit-icon {
  font-size: 28rpx;
}

/* 卡片 */
.card {
  background-color: #ffffff;
  margin: 24rpx;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

/* 身体数据 */
.body-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.body-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background-color: #F9F9F9;
  border-radius: 8rpx;
}

.body-stat__value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.body-stat__label {
  font-size: 20rpx;
  color: #999999;
}

/* BMI */
.bmi-section {
  margin-bottom: 20rpx;
}

.bmi-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.bmi-header__title {
  font-size: 24rpx;
  color: #666666;
}

.bmi-header__value {
  font-size: 36rpx;
  font-weight: 700;
}

.bmi-bar {
  position: relative;
  height: 24rpx;
  background-color: #E0E0E0;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.bmi-fill {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
  margin-left: -4rpx;
}

.bmi-ranges {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.bmi-range {
  position: absolute;
  height: 100%;
}

.bmi-range--underweight {
  background-color: rgba(255, 152, 0, 0.3);
}

.bmi-range--normal {
  background-color: rgba(76, 175, 80, 0.3);
}

.bmi-range--overweight {
  background-color: rgba(255, 193, 7, 0.3);
}

.bmi-range--obese {
  background-color: rgba(244, 67, 54, 0.3);
}

.bmi-status {
  display: block;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.bmi-advice {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #999999;
}

/* 理想体重 */
.ideal-weight {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background-color: #F9F9F9;
  border-radius: 8rpx;
}

.ideal-weight__label {
  font-size: 24rpx;
  color: #666666;
}

.ideal-weight__value {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
}

/* 代谢数据 */
.metabolism-stats {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.metabolism-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background-color: #F9F9F9;
  border-radius: 8rpx;
}

.metabolism-item__label {
  font-size: 24rpx;
  color: #666666;
}

.metabolism-item__value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.metabolism-item__unit {
  font-size: 22rpx;
  color: #999999;
  margin-left: 4rpx;
}

/* 营养目标 */
.nutrition-targets {
  margin-top: 24rpx;
}

.nutrition-targets__title {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.target-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.target-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 8rpx;
}

.target-item__value {
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.target-item__label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 目标进度 */
.goal-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.goal-current,
.goal-target {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.goal-current__label,
.goal-target__label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.goal-current__value,
.goal-target__value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.goal-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

.goal-time {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background-color: #F9F9F9;
  border-radius: 8rpx;
}

.goal-time__text {
  font-size: 24rpx;
  color: #666666;
  margin-right: 8rpx;
}

.goal-time__value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4CAF50;
  margin: 0 4rpx;
}

.goal-time__unit {
  font-size: 22rpx;
  color: #999999;
}

/* 设置列表 */
.settings-section {
  margin: 24rpx;
}

.settings-list {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item__left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.settings-item__icon {
  font-size: 32rpx;
}

.settings-item__label {
  font-size: 28rpx;
  color: #333333;
}

.settings-item__arrow {
  font-size: 40rpx;
  color: #CCCCCC;
}

/* 编辑弹窗 */
.edit-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.edit-dialog {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.edit-dialog__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.edit-dialog__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.edit-dialog__close {
  font-size: 32rpx;
  color: #999999;
  padding: 8rpx;
}

.edit-dialog__body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
}

/* 表单 */
.form-section {
  margin-bottom: 32rpx;
}

.form-section__title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item__label {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-item__input {
  width: 100%;
  height: 80rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.form-options {
  display: flex;
  gap: 12rpx;
}

.form-option {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.form-option--active {
  background-color: #4CAF50;
  color: #ffffff;
}

/* 目标选项 */
.goal-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.goal-option {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.goal-option--active {
  color: #ffffff;
}

/* 活动选项 */
.activity-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.activity-option {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.activity-option--active {
  background-color: #4CAF50;
  color: #ffffff;
}

.edit-dialog__footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.dialog-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.dialog-btn--cancel {
  background-color: #F5F5F5;
  color: #666666;
}

.dialog-btn--confirm {
  background-color: #4CAF50;
  color: #ffffff;
}
